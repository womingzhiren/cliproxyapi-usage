{
  "name": "cliproxyapi-usage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:ci": "npm run migrate:remote && wrangler deploy",
    "deploy:dry-run": "env HOME=/tmp XDG_CONFIG_HOME=/tmp wrangler deploy --dry-run --outdir /tmp/cliproxyapi-usage-dist",
    "migrate:local": "wrangler d1 migrations apply cliproxyapi-usage --local",
    "migrate:remote": "wrangler d1 migrations apply cliproxyapi-usage --remote",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "verify": "npm test && npm run check"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20260425.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
